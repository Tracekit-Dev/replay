{
  "name": "@tracekit/replay",
  "version": "0.2.1",
  "description": "TraceKit Session Replay - Privacy-first session recording with rrweb",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "rrweb": "2.0.0-alpha.20"
  },
  "peerDependencies": {
    "@tracekit/browser": "^0.1.1"
  },
  "devDependencies": {
    "@tracekit/browser": "^0.1.1",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tracekit-Dev/replay"
  },
  "keywords": [
    "tracekit",
    "session-replay",
    "rrweb",
    "observability",
    "privacy"
  ]
}
